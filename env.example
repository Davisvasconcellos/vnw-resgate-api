# Database Configuration
# Exemplo Dokploy (host interno)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@seu-host-interno:5432/seu_banco
# DB_SSL=false
#
# Exemplo Dokploy (host externo)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@SEU_IP_PUBLICO:5432/seu_banco
# DB_SSL=true

DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=false

# Para conexão via URL (Render, Railway, etc)
DATABASE_URL=

# Server Configuration
PORT=3000
NODE_ENV=development
API_PUBLIC_BASE_URL=

# JWT Configuration
JWT_SECRET=seu_jwt_secret_super_seguro_aqui
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Google Drive Integration (OAuth2) — Para upload de arquivos
GOOGLE_DRIVE_CLIENT_ID=seu_client_id_aqui
GOOGLE_DRIVE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_DRIVE_REDIRECT_URI=https://sua-api.onrender.com/api/v1/uploads/oauth/callback
GOOGLE_DRIVE_REFRESH_TOKEN=seu_refresh_token_aqui
GOOGLE_DRIVE_FOLDER_ID=id_da_pasta_raiz_no_drive

# Firebase Admin (Google Login)
FIREBASE_PROJECT_ID=seu_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu_project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
