# Database Configuration
# Exemplo Dokploy (host interno)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@seu-host-interno:5432/seu_banco
# DB_SSL=false
#
# Exemplo Dokploy (host externo)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@SEU_IP_PUBLICO:5432/seu_banco
# DB_SSL=true

DATABASE_URL=
DB_SSL=false

# Server Configuration
PORT=
NODE_ENV=development
API_PUBLIC_BASE_URL=

# JWT Configuration
JWT_SECRET=
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info


# Google Drive Integration (OAuth2)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_REDIRECT_URI=
GOOGLE_DRIVE_REFRESH_TOKEN=

# Firebase Admin SDK Configuration
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_PROJECT_ID=
